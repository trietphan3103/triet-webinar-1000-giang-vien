{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/submit", "destination": "/api/submit" },
    { "source": "/api/analytics/pixel", "destination": "/api/analytics/pixel" },
    { "source": "/api/analytics/ads", "destination": "/api/analytics/ads" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
